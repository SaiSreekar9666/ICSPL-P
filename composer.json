{
  "name": "yourname/icspl-admin-dashboard",
  "description": "Admin dashboard for ICSPL with secure login, user management, and file uploads.",
  "type": "project",
  "require": {
    "phpmailer/phpmailer": "^6.10",
    "vlucas/phpdotenv": "^5.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "includes/"
    },
    "files": [
      "includes/db_connection.php"
    ]
  },
  "scripts": {
    "start": "php -S localhost:8000 router.php"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
